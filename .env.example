# Polyglot Studio — environment configuration
#
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored; this template is safe to commit.

# Required. Your OpenRouter API key.
# Create one at https://openrouter.ai/settings/keys
# Server-side only — never sent to the browser.
OPENROUTER_API_KEY=

# Optional. Sent to OpenRouter as the HTTP-Referer header (for analytics
# on their dashboard). Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
